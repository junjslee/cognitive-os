// Figure 2 — control-plane interposition at the tool-call boundary · v1.0 RC.
// Rebuild:
//   dot -Tsvg docs/assets/src/architecture_v2.dot -o docs/assets/architecture_v2.svg
//   rsvg-convert --dpi-x 144 --dpi-y 144 docs/assets/architecture_v2.svg -o docs/assets/architecture_v2.png
//
// Arxiv ML-pipeline aesthetic. Three stratum-clusters (doxa / episteme / praxis)
// laid out top-to-bottom. The episteme cluster now carries four rows:
//   Row 1 · Hot-path hooks (guard, interceptor, telemetry) — the v0.11 surface
//   Row 2 · Pillar 1 · Blueprint Selector + Cascade Detector + Blueprint Validator
//   Row 3 · Pillar 2 · Hash Chain writer + two framework streams + pending contracts
//   Row 4 · Pillar 3 · Framework Query + Layer 8 spot-check + Phase 12 audit
// Shipped CP range: CP1-CP10 · 565/565 tests green.

digraph control_plane {
  graph [
    label     = <<br/><font point-size="18"><b>Figure 2 · Control-plane interposition at the tool-call boundary — v1.0 RC</b></font><br/><br/><font point-size="11" color="#5C5C5C">Tool-call intents cross <b>doxa → episteme</b> at PreToolUse; Pillar 1 selects a blueprint and Layers 2–4 + BP-D validators admit or reject.</font><br/><font point-size="11" color="#5C5C5C">PASS stamps a correlation id; Pillar 2 hash-chains the decision; Pillar 3 surfaces active guidance on the next op.</font><br/>>,
    labelloc  = "b",
    labeljust = "c",
    fontname  = "Helvetica",
    bgcolor   = "#FDFDFC",
    rankdir   = "TB",
    nodesep   = 0.4,
    ranksep   = 0.75,
    margin    = 0.4,
    splines   = "spline",
    pad       = 0.4,
    compound  = true
  ];

  node [
    shape     = "box",
    style     = "filled,rounded",
    fillcolor = "white",
    color     = "#1A1A1A",
    fontname  = "Helvetica",
    fontsize  = 11,
    fontcolor = "#1A1A1A",
    penwidth  = 0.9,
    margin    = "0.18,0.12"
  ];

  edge [
    color      = "#1A1A1A",
    fontname   = "Helvetica",
    fontsize   = 9,
    fontcolor  = "#5C5C5C",
    penwidth   = 0.9,
    arrowsize  = 0.7,
    arrowhead  = "vee"
  ];

  // ═══════════════════ DOXA band ═══════════════════
  subgraph cluster_doxa {
    label     = <<b>DOXA</b>  ·  AGENT RUNTIME>;
    fontname  = "Helvetica-Bold";
    fontsize  = 10;
    fontcolor = "#5C5C5C";
    style     = "rounded,dashed";
    color     = "#9A9A9A";
    margin    = 18;
    penwidth  = 0.7;

    doxa_llm  [label = <<b>LLM reasoning</b><br/><font point-size="9" color="#5C5C5C">tokens → tool-call intent</font>>];
    doxa_disp [label = <<b>Tool dispatcher</b><br/><font point-size="9" color="#5C5C5C">Bash · Write · Edit · MultiEdit</font>>];
    doxa_env  [label = <<b>Tool-use envelope</b><br/><font point-size="9" color="#5C5C5C">stdin JSON → PreToolUse hook</font>>];

    doxa_llm -> doxa_disp -> doxa_env [style = "invis", weight = 100];
    { rank = same; doxa_llm; doxa_disp; doxa_env; }
  }

  // ═══════════════════ EPISTEME band ═══════════════════
  subgraph cluster_episteme {
    label     = <<b>EPISTEME</b>  ·  CONTROL PLANE  ·  three pillars · p95 &lt; 100 ms>;
    fontname  = "Helvetica-Bold";
    fontsize  = 10;
    fontcolor = "#7A2E2A";
    style     = "rounded,dashed";
    color     = "#7A2E2A";
    margin    = 22;
    penwidth  = 0.9;

    // ── Row 1 · hot-path hooks (v0.11 surface) ──
    subgraph cluster_ep_row1 {
      label    = "";
      color    = "transparent";
      margin   = 0;

      guard [
        label    = <<b>Reasoning-Surface Guard</b><br/><font point-size="9" color="#7A2E2A">PreToolUse · STRICT default</font><br/><font point-size="9" color="#5C5C5C">K · U · A · D · verification_trace</font>>,
        color    = "#7A2E2A",
        penwidth = 1.4
      ];
      interceptor [label = <<b>Stateful Interceptor</b><br/><font point-size="9" color="#5C5C5C">PostToolUse · cross-call memory</font><br/><font point-size="9" color="#5C5C5C">sha256 + ts · deep-scan on execute</font>>];
      telemetry   [label = <<b>Calibration Telemetry</b><br/><font point-size="9" color="#5C5C5C">pre ⇄ post · correlation_id</font><br/><font point-size="9" color="#5C5C5C">exit_code · stderr · duration</font>>];

      { rank = same; guard; interceptor; telemetry; }
      guard -> interceptor -> telemetry [style = "invis", weight = 100];
    }

    // ── Row 2 · Pillar 1 · Cognitive Blueprints ──
    subgraph cluster_ep_row2 {
      label    = "";
      color    = "transparent";
      margin   = 0;

      selector [
        label    = <<b>Blueprint Selector</b>  <font point-size="9" color="#2C6E49"><b>P1</b></font><br/><font point-size="9" color="#5C5C5C">Axiomatic · Fence · Conseq-Chain</font><br/><font point-size="9" color="#5C5C5C">Blueprint D · generic fallback</font>>,
        color    = "#2C6E49",
        penwidth = 1.2
      ];
      cascade [
        label    = <<b>Cascade Detector</b>  <font point-size="9" color="#2C6E49"><b>P1 · CP10</b></font><br/><font point-size="9" color="#5C5C5C">4 triggers · self-escalation</font><br/><font point-size="9" color="#5C5C5C">sensitive-path · cross-ref · generated</font>>,
        color    = "#2C6E49",
        penwidth = 1.2
      ];
      validator [
        label    = <<b>Blueprint Validator</b>  <font point-size="9" color="#2C6E49"><b>P1</b></font><br/><font point-size="9" color="#5C5C5C">L2 classify · L3 ground · L4 trace</font><br/><font point-size="9" color="#5C5C5C">BP-D 6-field · Fence 5-field</font>>,
        color    = "#2C6E49",
        penwidth = 1.2
      ];

      { rank = same; selector; cascade; validator; }
      selector -> cascade -> validator [style = "invis", weight = 100];
    }

    // ── Row 3 · Pillar 2 · Append-Only Hash Chain ──
    subgraph cluster_ep_row3 {
      label    = "";
      color    = "transparent";
      margin   = 0;

      chain [
        label    = <<b>Chain Writer</b>  <font point-size="9" color="#1F4E79"><b>P2 · CP7</b></font><br/><font point-size="9" color="#5C5C5C">cp7-chained-v1 envelope</font><br/><font point-size="9" color="#5C5C5C">SHA-256 · prev_hash · fcntl.flock</font>>,
        color    = "#1F4E79",
        penwidth = 1.2
      ];
      protocols [
        label    = <<b>protocols.jsonl</b>  <font point-size="9" color="#1F4E79"><b>P2 · P3 producer</b></font><br/><font point-size="9" color="#5C5C5C">Fence synth first producer (CP5)</font><br/><font point-size="9" color="#5C5C5C">Axiomatic + BP-D in v1.0.1</font>>,
        color    = "#1F4E79",
        penwidth = 1.2
      ];
      deferred [
        label    = <<b>deferred_discoveries.jsonl</b>  <font point-size="9" color="#1F4E79"><b>P2 · CP10</b></font><br/><font point-size="9" color="#5C5C5C">BP-D adjacent-gap log</font><br/><font point-size="9" color="#5C5C5C">hash-chained at PreToolUse</font>>,
        color    = "#1F4E79",
        penwidth = 1.2
      ];
      pending [
        label    = <<b>pending_contracts</b>  <font point-size="9" color="#1F4E79"><b>P2 · CP7</b></font><br/><font point-size="9" color="#5C5C5C">Layer 6 write · 72h grace</font><br/><font point-size="9" color="#5C5C5C">idempotent · collision-reject</font>>,
        color    = "#1F4E79",
        penwidth = 1.0
      ];

      { rank = same; chain; protocols; deferred; pending; }
      chain -> protocols -> deferred -> pending [style = "invis", weight = 100];
    }

    // ── Row 4 · Pillar 3 · Framework Synthesis & Active Guidance ──
    subgraph cluster_ep_row4 {
      label    = "";
      color    = "transparent";
      margin   = 0;

      framework_query [
        label    = <<b>Framework Query</b>  <font point-size="9" color="#6A3083"><b>P3 · CP9</b></font><br/><font point-size="9" color="#5C5C5C">PreToolUse · one advisory per op</font><br/><font point-size="9" color="#5C5C5C">verdict-filtered · never blocks</font>>,
        color    = "#6A3083",
        penwidth = 1.2
      ];
      spot_check [
        label    = <<b>Layer 8 spot-check</b>  <font point-size="9" color="#6A3083"><b>P3 · CP8</b></font><br/><font point-size="9" color="#5C5C5C">10% → 5% at 30d · BP-D 2×</font><br/><font point-size="9" color="#5C5C5C">episteme review CLI</font>>,
        color    = "#6A3083",
        penwidth = 1.2
      ];
      phase12 [
        label    = <<b>Phase 12 audit</b>  <font point-size="9" color="#6A3083"><b>P3 · shipped</b></font><br/><font point-size="9" color="#5C5C5C">chain_integrity gated</font><br/><font point-size="9" color="#5C5C5C">friction-weighted axis rescore</font>>,
        color    = "#6A3083",
        penwidth = 1.2
      ];
      guide_cli [
        label    = <<b>episteme guide</b>  <font point-size="9" color="#6A3083"><b>P3 · CP9</b></font><br/><font point-size="9" color="#5C5C5C">SessionStart digest</font><br/><font point-size="9" color="#5C5C5C">--context · --since · --deferred</font>>,
        color    = "#6A3083",
        penwidth = 1.0
      ];

      { rank = same; framework_query; spot_check; phase12; guide_cli; }
      framework_query -> spot_check -> phase12 -> guide_cli [style = "invis", weight = 100];
    }

    // Invisible down-edges between rows (lock order 1 → 2 → 3 → 4)
    guard       -> selector        [style = "invis", weight = 5];
    interceptor -> cascade         [style = "invis", weight = 5];
    telemetry   -> validator       [style = "invis", weight = 5];
    selector    -> chain           [style = "invis", weight = 5];
    cascade     -> protocols       [style = "invis", weight = 5];
    validator   -> deferred        [style = "invis", weight = 5];
    chain       -> framework_query [style = "invis", weight = 5];
    protocols   -> spot_check      [style = "invis", weight = 5];
    deferred    -> phase12         [style = "invis", weight = 5];
    pending     -> guide_cli       [style = "invis", weight = 5];

    // Within-band visible flows
    selector  -> validator   [label = "field contract"];
    cascade   -> validator   [label = "BP-D", constraint = false];
    validator -> guard       [label = "admit/reject", style = "dashed", constraint = false];
    telemetry -> chain       [label = "write\nenvelope"];
    protocols -> framework_query [label = "query", style = "dashed", constraint = false];
    deferred  -> guide_cli   [label = "--deferred", style = "dashed", constraint = false];
    spot_check -> phase12    [label = "verdict queue"];
    phase12   -> guard       [
      label      = "profile-axis\nrescore",
      style      = "dashed",
      color      = "#6A3083",
      fontcolor  = "#6A3083",
      constraint = false
    ];
  }

  // ═══════════════════ PRAXIS band ═══════════════════
  subgraph cluster_praxis {
    label     = <<b>PRAXIS</b>  ·  HARDWARE · OPERATING SYSTEM>;
    fontname  = "Helvetica-Bold";
    fontsize  = 10;
    fontcolor = "#5C5C5C";
    style     = "rounded,dashed";
    color     = "#9A9A9A";
    margin    = 18;
    penwidth  = 0.7;

    praxis_proc   [label = <<b>Process</b><br/><font point-size="9" color="#5C5C5C">fork · exec · fd</font>>];
    praxis_state  [label = <<b>Persistent state</b><br/><font point-size="9" color="#5C5C5C">fs · git tree · lockfile</font>>];
    praxis_remote [label = <<b>Remote effect</b><br/><font point-size="9" color="#5C5C5C">push · publish · deploy</font>>];

    praxis_proc -> praxis_state -> praxis_remote [style = "invis", weight = 100];
    { rank = same; praxis_proc; praxis_state; praxis_remote; }
  }

  // ═══════════════════ Cross-band edges ═══════════════════

  // Doxa → Guard (tool call)
  doxa_env -> guard [label = "PreToolUse\ncp7-chained-v1"];

  // BLOCK (accent) — guard back to dispatcher
  guard -> doxa_disp [
    label      = <<font color="#7A2E2A"><b>BLOCK · exit 2</b></font>>,
    color      = "#7A2E2A",
    fontcolor  = "#7A2E2A",
    penwidth   = 1.4,
    constraint = false
  ];

  // Framework advisory — emits stderr, never blocks
  framework_query -> doxa_disp [
    label      = <<font color="#6A3083"><i>advisory · never blocks</i></font>>,
    color      = "#6A3083",
    fontcolor  = "#6A3083",
    style      = "dashed",
    constraint = false
  ];

  // PASS — guard to praxis (minlen forces praxis below row 4)
  guard -> praxis_state [label = "PASS · exit 0\ncorrelation_id stamped", minlen = 3, weight = 3];

  // Invisible spacers forcing praxis below row 4
  framework_query -> praxis_proc   [style = "invis", weight = 5];
  spot_check      -> praxis_state  [style = "invis", weight = 5];
  phase12         -> praxis_remote [style = "invis", weight = 5];

  // PostToolUse record — praxis back up to chain writer (dashed, hash-chained)
  praxis_state -> chain [
    label      = <<font color="#1F4E79">PostToolUse · hash-chained</font>>,
    color      = "#1F4E79",
    fontcolor  = "#1F4E79",
    style      = "dashed",
    constraint = false
  ];

  // Stateful-interceptor memory loop — lateral, within row 1
  interceptor -> guard [
    label      = "deep-scan\non execute",
    style      = "dashed",
    constraint = false
  ];
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-os.dev/schemas/substrate-v1/pull_query.json",
  "title": "Substrate Pull Query v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "contract_version": {"type": "string", "const": "substrate-v1"},
    "query": {"type": ["string", "null"], "description": "Free-text semantic/keyword query. Null means: list by scope only."},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user_id": {"type": ["string", "null"]},
        "project_id": {"type": ["string", "null"]},
        "agent_id": {"type": ["string", "null"]},
        "session_id": {"type": ["string", "null"]},
        "run_id": {"type": ["string", "null"]},
        "app_id": {"type": ["string", "null"]},
        "org_id": {"type": ["string", "null"]}
      }
    },
    "limit": {"type": "integer", "minimum": 1, "maximum": 1000, "default": 50},
    "since": {"type": ["string", "null"], "format": "date-time"}
  }
}
